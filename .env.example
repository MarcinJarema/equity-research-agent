# Skopiuj do .env i uzupełnij. Plik .env jest w .gitignore — nie trafia na GitHuba.

# --- Wybór dostawcy LLM (abstrakcja LLMClient) ---
# Dozwolone: groq | openai | anthropic
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# Klucze API — uzupełnij tylko tego dostawcę, którego używasz.
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Kontrola kosztów ---
MAX_TOKENS=1024
LLM_TEMPERATURE=0.2

# --- Observability (ETAP 4) ---
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=equity-research-agent
# Konta z UE: użyj https://eu.api.smith.langchain.com (inaczej API zwraca 403).
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# --- RAG / pgvector (ETAP 3) ---
# localhost:5433 przy uruchamianiu z hosta (5432 bywa zajęty przez lokalnego
# Postgresa); docker-compose nadpisuje host na 'db' wewnątrz sieci kontenerów.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/equity
# Embedder: sentence-transformers (lokalny model) lub fake (bez torcha, do testów).
EMBED_PROVIDER=sentence-transformers
