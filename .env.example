# Skopiuj do .env i uzupełnij. Plik .env jest w .gitignore — nie trafia na GitHuba.

# --- Wybór dostawcy LLM (abstrakcja LLMClient) ---
# Dozwolone: groq | openai | anthropic
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# Klucze API — uzupełnij tylko tego dostawcę, którego używasz.
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Kontrola kosztów ---
MAX_TOKENS=1024
LLM_TEMPERATURE=0.2

# --- Observability (ETAP 4) ---
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=equity-research-agent

# --- RAG / pgvector (ETAP 3) ---
DATABASE_URL=postgresql://postgres:postgres@db:5432/equity
